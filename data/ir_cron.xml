<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Transcription worker: picks up to 10 pending recordings per tick and
         feeds them to crm.call.voice.config's selected provider. Inactive on
         install — admin activates by turning the master toggle ON in
         Configuration → Voice Transcription. -->
    <record id="cron_crm_call_recorder_transcribe" model="ir.cron">
        <field name="name">CRM Call Recorder: Transcribe Pending Recordings</field>
        <field name="model_id" ref="model_crm_call_recording"/>
        <field name="state">code</field>
        <field name="code">model._run_transcription_batch(limit=10)</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
