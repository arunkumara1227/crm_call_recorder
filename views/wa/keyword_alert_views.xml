<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Alert Rules: List -->
    <!-- ============================================================ -->
    <record id="view_wa_keyword_alert_rule_list" model="ir.ui.view">
        <field name="name">wa.keyword.alert.rule.list</field>
        <field name="model">wa.keyword.alert.rule</field>
        <field name="arch" type="xml">
            <list string="Keyword Alert Rules" editable="bottom">
                <field name="name"/>
                <field name="category"
                       widget="badge"
                       decoration-danger="category == 'data_leak'"
                       decoration-warning="category in ('policy', 'profanity')"
                       decoration-info="category == 'competitor'"/>
                <field name="severity"
                       widget="badge"
                       decoration-danger="severity in ('critical', 'high')"
                       decoration-warning="severity == 'medium'"
                       decoration-info="severity == 'low'"/>
                <field name="match_type"/>
                <field name="keywords" widget="text"/>
                <field name="alert_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Alert Rules: Form -->
    <record id="view_wa_keyword_alert_rule_form" model="ir.ui.view">
        <field name="name">wa.keyword.alert.rule.form</field>
        <field name="model">wa.keyword.alert.rule</field>
        <field name="arch" type="xml">
            <form string="Alert Rule">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_alerts"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-exclamation-triangle">
                            <field name="alert_count" widget="statinfo" string="Alerts"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category"/>
                            <field name="severity"/>
                            <field name="match_type"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                    <group string="Keywords (one per line)">
                        <field name="keywords" nolabel="1" placeholder="Enter keywords, one per line..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Alert Logs: List -->
    <!-- ============================================================ -->
    <record id="view_wa_keyword_alert_log_list" model="ir.ui.view">
        <field name="name">wa.keyword.alert.log.list</field>
        <field name="model">wa.keyword.alert.log</field>
        <field name="arch" type="xml">
            <list string="Keyword Alerts"
                   decoration-danger="severity in ('critical', 'high')"
                   decoration-warning="severity == 'medium'"
                   decoration-muted="status in ('reviewed', 'dismissed')">
                <field name="message_date" widget="datetime"/>
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="department_id" optional="hide"/>
                <field name="rule_id"/>
                <field name="category"
                       widget="badge"
                       decoration-danger="category == 'data_leak'"
                       decoration-warning="category in ('policy', 'profanity')"
                       decoration-info="category == 'competitor'"/>
                <field name="severity"
                       widget="badge"
                       decoration-danger="severity in ('critical', 'high')"
                       decoration-warning="severity == 'medium'"/>
                <field name="matched_keywords"/>
                <field name="message_direction"
                       widget="badge"
                       decoration-info="message_direction == 'outgoing'"
                       decoration-success="message_direction == 'incoming'"/>
                <field name="phone"/>
                <field name="message_text" widget="text"/>
                <field name="status"
                       widget="badge"
                       decoration-danger="status == 'new'"
                       decoration-warning="status == 'escalated'"
                       decoration-success="status == 'reviewed'"
                       decoration-muted="status == 'dismissed'"/>
                <field name="reviewer_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Alert Logs: Form -->
    <record id="view_wa_keyword_alert_log_form" model="ir.ui.view">
        <field name="name">wa.keyword.alert.log.form</field>
        <field name="model">wa.keyword.alert.log</field>
        <field name="arch" type="xml">
            <form string="Keyword Alert">
                <header>
                    <button name="action_mark_reviewed"
                            string="Mark Reviewed"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'new'"/>
                    <button name="action_escalate"
                            string="Escalate"
                            type="object"
                            class="btn-warning"
                            invisible="status not in ('new', 'reviewed')"/>
                    <button name="action_dismiss"
                            string="Dismiss"
                            type="object"
                            invisible="status not in ('new', 'reviewed')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="new,reviewed,escalated,dismissed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Alert Details">
                            <field name="rule_id"/>
                            <field name="category"/>
                            <field name="severity"/>
                            <field name="matched_keywords"/>
                        </group>
                        <group string="Employee / Message">
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="message_date"/>
                            <field name="message_direction"/>
                            <field name="phone"/>
                            <field name="partner_id"/>
                        </group>
                    </group>
                    <group string="Message Content">
                        <field name="message_text" nolabel="1" colspan="2" readonly="1"/>
                    </group>
                    <group string="Review" invisible="status == 'new'">
                        <field name="reviewer_id"/>
                        <field name="review_date"/>
                        <field name="review_notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Alert Logs: Search -->
    

    <!-- ============================================================ -->
    <!-- Actions -->
    <!-- ============================================================ -->
    <record id="action_wa_keyword_alert_rules" model="ir.actions.act_window">
        <field name="name">Alert Rules</field>
        <field name="res_model">wa.keyword.alert.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_wa_keyword_alert_log" model="ir.actions.act_window">
        <field name="name">Keyword Alerts</field>
        <field name="res_model">wa.keyword.alert.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No alerts triggered
            </p>
            <p>
                Alerts will appear here when employee messages match configured keyword rules.
            </p>
        </field>
    </record>

</odoo>
