<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Dashboard: Employee Kanban Cards (Main Dashboard) -->
    <!-- ============================================================ -->
    <record id="view_wa_employee_session_kanban" model="ir.ui.view">
        <field name="name">wa.employee.session.kanban</field>
        <field name="model">wa.employee.session</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1" action="action_open_chats" type="object">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="phone_number"/>
                <field name="session_status"/>
                <field name="monitoring_enabled"/>
                <field name="total_messages"/>
                <field name="total_sent"/>
                <field name="total_received"/>
                <field name="today_sent"/>
                <field name="today_received"/>
                <field name="unique_contacts"/>
                <field name="alert_count"/>
                <field name="avg_response_minutes"/>
                <field name="quality_score"/>
                <field name="last_activity"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex flex-column p-2" style="border-radius: 12px; overflow: hidden;">
                            <!-- Header: Employee name + Status -->
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="d-flex align-items-center">
                                    <i class="fa fa-user-circle fa-2x text-primary me-2"/>
                                    <div>
                                        <strong class="fs-5"><field name="employee_id"/></strong>
                                        <div class="text-muted small"><field name="department_id"/></div>
                                    </div>
                                </div>
                                <span t-if="record.session_status.raw_value == 'connected'" class="badge rounded-pill bg-success">Online</span>
                                <span t-elif="record.session_status.raw_value == 'disconnected'" class="badge rounded-pill bg-danger">Offline</span>
                                <span t-else="" class="badge rounded-pill bg-warning">Waiting</span>
                            </div>

                            <!-- Phone -->
                            <div class="text-muted small mb-2">
                                <i class="fa fa-whatsapp text-success me-1"/>
                                <field name="phone_number"/>
                            </div>

                            <!-- Stats Row 1: Messages -->
                            <div class="d-flex justify-content-between mb-1 px-1">
                                <div class="text-center">
                                    <div class="fw-bold text-primary fs-5"><field name="total_messages"/></div>
                                    <div class="text-muted small">Total</div>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold text-info fs-5"><field name="total_sent"/></div>
                                    <div class="text-muted small">Sent</div>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold text-success fs-5"><field name="total_received"/></div>
                                    <div class="text-muted small">Received</div>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold text-dark fs-5"><field name="unique_contacts"/></div>
                                    <div class="text-muted small">Contacts</div>
                                </div>
                            </div>

                            <hr class="my-1"/>

                            <!-- Stats Row 2: Today -->
                            <div class="d-flex justify-content-between mb-1 px-1">
                                <div class="small">
                                    <i class="fa fa-arrow-up text-info me-1"/>
                                    <span class="fw-bold"><field name="today_sent"/></span> sent today
                                </div>
                                <div class="small">
                                    <i class="fa fa-arrow-down text-success me-1"/>
                                    <span class="fw-bold"><field name="today_received"/></span> recv today
                                </div>
                            </div>

                            <!-- Stats Row 3: Response Time + Quality + Alerts -->
                            <div class="d-flex justify-content-between px-1 mt-1">
                                <div class="small">
                                    <i class="fa fa-clock-o text-warning me-1"/>
                                    <span class="fw-bold"><field name="avg_response_minutes"/></span> min avg
                                </div>
                                <div class="small">
                                    <i class="fa fa-star text-warning me-1"/>
                                    <span class="fw-bold"><field name="quality_score"/></span>/100
                                </div>
                                <div class="small">
                                    <i class="fa fa-exclamation-triangle me-1" t-attf-class="#{record.alert_count.raw_value > 0 ? 'text-danger' : 'text-muted'}"/>
                                    <span class="fw-bold"><field name="alert_count"/></span> alerts
                                </div>
                            </div>

                            <!-- Last Activity -->
                            <div class="text-muted small mt-2 text-end">
                                <i class="fa fa-clock-o me-1"/>
                                Last: <field name="last_activity" widget="relative"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Dashboard Action: Employee Overview (Kanban first) -->
    <record id="action_wa_tracker_dashboard" model="ir.actions.act_window">
        <field name="name">Employee Dashboard</field>
        <field name="res_model">wa.employee.session</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No employees being tracked yet
            </p>
            <p>Go to Configuration → Employee Sessions to assign WhatsApp sessions to employees.</p>
        </field>
    </record>

    <!-- Dashboard Action: Message Volume by Employee (Graph) -->
    <record id="action_wa_dashboard_volume" model="ir.actions.act_window">
        <field name="name">Message Volume</field>
        <field name="res_model">wa.communication.log</field>
        <field name="view_mode">graph,pivot,list</field>
    </record>

    <!-- Dashboard Action: Activity Hours Heatmap (Pivot) -->
    <record id="action_wa_dashboard_activity_hours" model="ir.actions.act_window">
        <field name="name">Activity by Hour</field>
        <field name="res_model">wa.communication.log</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <!-- Dashboard Action: Alerts Overview -->
    <record id="action_wa_dashboard_alerts" model="ir.actions.act_window">
        <field name="name">Alerts Overview</field>
        <field name="res_model">wa.keyword.alert.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Dashboard Action: Quality Score Trends -->
    <record id="action_wa_dashboard_quality" model="ir.actions.act_window">
        <field name="name">Quality Trends</field>
        <field name="res_model">wa.quality.score</field>
        <field name="view_mode">graph,pivot,list,form</field>
    </record>

</odoo>
