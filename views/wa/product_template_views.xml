<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_wa" model="ir.ui.view">
        <field name="name">product.template.form.inherit.wa</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='list_price_uom']" position="after">
                <label for="wa_retail_price" string="Retail Price (WhatsApp)"/>
                <div class="o_row">
                    <field name="wa_retail_price" class="oe_inline" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
