<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Login page ────────────────────────────────────────────────── -->
    <template id="web_login" name="Call Recorder Web Login">
        <html lang="en">
        <head>
            <meta charset="UTF-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
            <title>Alphalize CRM — Login</title>
            <link rel="stylesheet"
                  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
            <link rel="stylesheet"
                  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
            <link rel="stylesheet" href="/crm_call_recorder/static/src/web/css/web_app.css"/>
        </head>
        <body class="bg-light">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-12 col-sm-10 col-md-6 col-lg-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-4">
                                <div class="text-center mb-4">
                                    <img src="/crm_call_recorder/static/src/img/alphalize_logo.png"
                                         alt="Alphalize"
                                         style="height:64px;width:64px;border-radius:10px;"
                                         onerror="this.outerHTML='&lt;div style=&quot;font-size:3rem;line-height:1;&quot;&gt;📞&lt;/div&gt;'"/>
                                    <h3 class="fw-bold mt-2 mb-0">Alphalize CRM</h3>
                                    <p class="text-muted small mb-0">
                                        Sign in to your Odoo account
                                    </p>
                                </div>

                                <div t-if="error" class="alert alert-danger small py-2">
                                    <t t-esc="error"/>
                                </div>

                                <form method="post" action="/calls/login/submit">
                                    <div class="mb-3">
                                        <label class="form-label small fw-semibold">Email / Username</label>
                                        <input type="text" class="form-control" name="login"
                                               required="required" autocomplete="username"
                                               autofocus="autofocus"/>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-semibold">Password</label>
                                        <input type="password" class="form-control" name="password"
                                               required="required" autocomplete="current-password"/>
                                    </div>
                                    <button type="submit" class="btn btn-primary w-100">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>Log in
                                    </button>
                                </form>

                                <div class="text-center mt-3">
                                    <a href="/odoo" class="small text-muted">
                                        Use Odoo backend instead
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </body>
        </html>
    </template>

    <!-- ─── Access denied page ──────────────────────────────────────── -->
    <template id="web_access_denied" name="Call Recorder Access Denied">
        <html lang="en">
        <head>
            <meta charset="UTF-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
            <title>Alphalize CRM — Access Denied</title>
            <link rel="stylesheet"
                  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
        </head>
        <body class="bg-light">
            <div class="container py-5 text-center">
                <div style="font-size:4rem;">🚫</div>
                <h3 class="mt-3">Access Denied</h3>
                <p class="text-muted">
                    Hi <t t-esc="user.name"/>, you don't have permission to use
                    the Call Recorder Web app. Ask your manager to grant you the
                    "Call Recorder / User" role.
                </p>
                <a href="/calls/logout" class="btn btn-outline-secondary mt-3">
                    <i class="bi bi-box-arrow-right me-1"></i>Log out
                </a>
                <a href="/odoo" class="btn btn-outline-primary mt-3 ms-2">
                    Go to Odoo backend
                </a>
            </div>
        </body>
        </html>
    </template>

    <!-- ─── Main app shell ──────────────────────────────────────────── -->
    <template id="web_app" name="Call Recorder Web App">
        <html lang="en">
        <head>
            <meta charset="UTF-8"/>
            <meta name="viewport"
                  content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
            <title>Alphalize CRM</title>
            <link rel="stylesheet"
                  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
            <link rel="stylesheet"
                  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
            <link rel="stylesheet" href="/crm_call_recorder/static/src/web/css/web_app.css"/>
        </head>
        <body class="bg-light">

            <!-- Top bar -->
            <nav class="navbar navbar-dark bg-primary sticky-top px-3 py-2">
                <span class="navbar-brand mb-0 fw-bold d-flex align-items-center gap-2">
                    <img src="/crm_call_recorder/static/src/img/alphalize_logo.png"
                         alt="Alphalize"
                         style="height:32px;width:32px;border-radius:6px;background:#fff;padding:2px;"
                         onerror="this.style.display='none'"/>
                    <span>Alphalize CRM</span>
                </span>
                <div class="d-flex align-items-center gap-2">
                    <button id="cr-bell" class="btn btn-sm btn-outline-light position-relative" title="Notifications">
                        <i class="bi bi-bell"></i>
                        <span id="cr-bell-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none;">0</span>
                    </button>
                    <span class="text-light small d-none d-sm-inline">
                        <i class="bi bi-person-circle me-1"></i>
                        <t t-esc="user.name"/>
                    </span>
                    <a href="/calls/logout"
                       class="btn btn-sm btn-outline-light"
                       title="Log out">
                        <i class="bi bi-box-arrow-right"></i>
                    </a>
                </div>
            </nav>

            <!-- Tab bar -->
            <div class="cr-tabbar bg-white border-bottom shadow-sm">
                <div class="cr-tabs">
                    <button class="cr-tab active" data-tab="dashboard">
                        <i class="bi bi-grid-1x2"></i>
                        <span>Dashboard</span>
                    </button>
                    <button class="cr-tab" data-tab="recordings">
                        <i class="bi bi-mic-fill"></i>
                        <span>Recordings</span>
                    </button>
                    <button class="cr-tab" data-tab="tone">
                        <i class="bi bi-emoji-smile"></i>
                        <span>Tone</span>
                    </button>
                    <button class="cr-tab" data-tab="whatsapp">
                        <i class="bi bi-whatsapp"></i>
                        <span>WhatsApp</span>
                    </button>
                    <button class="cr-tab" data-tab="pipeline">
                        <i class="bi bi-kanban"></i>
                        <span>Pipeline</span>
                    </button>
                    <button class="cr-tab" data-tab="apikeys">
                        <i class="bi bi-key"></i>
                        <span>Keys</span>
                    </button>
                    <button t-if="is_manager"
                            class="cr-tab" data-tab="settings">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                    </button>
                </div>
            </div>

            <!-- App content -->
            <main id="app" class="cr-app pb-4">
                <div class="text-center text-muted py-5">
                    <div class="spinner-border" role="status"/>
                    <div class="small mt-2">Loading…</div>
                </div>
            </main>

            <!-- Modal scaffold -->
            <div class="modal fade" id="cr-modal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="cr-modal-title">Title</h5>
                            <button type="button" class="btn-close"
                                    data-bs-dismiss="modal" aria-label="Close"/>
                        </div>
                        <div class="modal-body" id="cr-modal-body"/>
                        <div class="modal-footer" id="cr-modal-footer"/>
                    </div>
                </div>
            </div>

            <!-- Toast region -->
            <div class="toast-container position-fixed bottom-0 end-0 p-3"
                 id="cr-toasts" style="z-index:1080;"/>

            <!-- Bootstrap bundle (popper + JS) -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"/>

            <!-- Server-injected user info (Markup so QWeb doesn't HTML-escape JSON) -->
            <script>
                window.CR_USER = <t t-out="user_json"/>;
            </script>

            <!-- Main app -->
            <script src="/crm_call_recorder/static/src/web/js/web_app.js"/>
        </body>
        </html>
    </template>

</odoo>
