<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level "Call Recorder" menu under Sales root -->
    <menuitem id="menu_call_recorder_root"
              name="Call Recorder"
              parent="sale.sale_menu_root"
              sequence="60"
              groups="crm_call_recorder.group_call_recorder_user"/>

    <menuitem id="menu_call_recordings"
              name="Recordings"
              parent="menu_call_recorder_root"
              action="action_crm_call_recording"
              sequence="10"
              groups="crm_call_recorder.group_call_recorder_user"/>

    <!-- Configuration submenu (manager-only) -->
    <menuitem id="menu_call_recorder_config"
              name="Configuration"
              parent="menu_call_recorder_root"
              sequence="90"
              groups="crm_call_recorder.group_call_recorder_manager"/>

    <menuitem id="menu_call_recorder_voice_config"
              name="Voice Transcription"
              parent="menu_call_recorder_config"
              action="action_crm_call_voice_config"
              sequence="10"
              groups="crm_call_recorder.group_call_recorder_manager"/>

    <menuitem id="menu_call_recorder_tone_keywords"
              name="Tone Keywords"
              parent="menu_call_recorder_config"
              action="action_crm_call_tone_keyword"
              sequence="20"
              groups="crm_call_recorder.group_call_recorder_manager"/>

    <!-- ─── Tone Analysis section (user-visible) ─── -->
    <menuitem id="menu_call_recorder_tone_root"
              name="Tone Analysis"
              parent="menu_call_recorder_root"
              sequence="30"
              groups="crm_call_recorder.group_call_recorder_user"/>

    <menuitem id="menu_call_recorder_tone_report"
              name="Tone Report"
              parent="menu_call_recorder_tone_root"
              action="action_crm_call_tone_report"
              sequence="10"
              groups="crm_call_recorder.group_call_recorder_user"/>

    <menuitem id="menu_call_recorder_tone_all"
              name="All Tones"
              parent="menu_call_recorder_tone_root"
              action="action_crm_call_tone_all"
              sequence="20"
              groups="crm_call_recorder.group_call_recorder_user"/>

    <menuitem id="menu_call_recorder_tone_harsh"
              name="Harsh Calls"
              parent="menu_call_recorder_tone_root"
              action="action_crm_call_tone_harsh"
              sequence="30"
              groups="crm_call_recorder.group_call_recorder_user"/>

</odoo>
